rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        'admin' in get(/databases/$(database)/documents/users/$(request.auth.uid)).data.roles;
    }

    function isTenant(tenantId) {
      return isAuthenticated() && request.auth.uid == tenantId;
    }

    function isClient() {
      return isAuthenticated() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        'client' in get(/databases/$(database)/documents/users/$(request.auth.uid)).data.roles;
    }

    function isWidget(tenantId, pluginId) {
      return isAuthenticated() &&
        request.auth.token.get('role', '') == 'widget' &&
        request.auth.token.get('snap_tenantId', '') == tenantId &&
        request.auth.token.get('snap_pluginId', '') == pluginId;
    }

    function clientHasPluginAccess(pluginId) {
      return isAuthenticated() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        pluginId in get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('clientAccess', []);
    }

    function hasTenantShareAccess(pluginId) {
      return isAuthenticated() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        pluginId in get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('sharedPluginAccess', []);
    }

    // Users collection
    match /users/{uid} {
      allow read: if isAuthenticated() && (request.auth.uid == uid || isAdmin());
      allow write: if isAuthenticated() && (request.auth.uid == uid || isAdmin());
    }

    // Tenants collection
    match /tenants/{tenantId} {
      allow read, write: if isTenant(tenantId) || isAdmin();

      match /connections/{connectionId} {
        allow read, write: if isTenant(tenantId) || isAdmin();
      }

      match /snapPlugins/{pluginId} {
        allow read: if isTenant(tenantId) || isAdmin() || clientHasPluginAccess(pluginId) || isWidget(tenantId, pluginId) || hasTenantShareAccess(pluginId);
        allow write: if isTenant(tenantId) || isAdmin();
      }

      match /api_keys/{apiKeyId} {
        allow read, write: if isTenant(tenantId) || isAdmin();
      }
    }

    // Connection registry (one Knack app per tenant)
    match /connectionRegistry/{appId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Snap submissions
    match /snap_submissions/{submissionId} {
      allow read: if isAuthenticated() && (
        isAdmin() ||
        resource.data.tenantId == request.auth.uid ||
        clientHasPluginAccess(resource.data.pluginId) ||
        hasTenantShareAccess(resource.data.pluginId) ||
        (request.auth.token.get('role', '') == 'widget' && resource.data.knackUserId == request.auth.token.get('knackUserId', ''))
      );
      // Create: tenant must own the submission, or widget token claims must match (H-03)
      allow create: if isAuthenticated() && (
        request.resource.data.tenantId == request.auth.uid ||
        (
          request.auth.token.get('role', '') == 'widget' &&
          request.resource.data.tenantId == request.auth.token.get('snap_tenantId', '') &&
          request.resource.data.pluginId  == request.auth.token.get('snap_pluginId',  '')
        )
      );
      allow update: if isAuthenticated() && (
        isAdmin() ||
        resource.data.tenantId == request.auth.uid ||
        clientHasPluginAccess(resource.data.pluginId) ||
        hasTenantShareAccess(resource.data.pluginId)
      );
      allow delete: if isAdmin() || resource.data.tenantId == request.auth.uid || hasTenantShareAccess(resource.data.pluginId);

      match /comments/{commentId} {
        allow read: if isAuthenticated() && (
          isAdmin() ||
          get(/databases/$(database)/documents/snap_submissions/$(submissionId)).data.tenantId == request.auth.uid ||
          clientHasPluginAccess(get(/databases/$(database)/documents/snap_submissions/$(submissionId)).data.pluginId) ||
          hasTenantShareAccess(get(/databases/$(database)/documents/snap_submissions/$(submissionId)).data.pluginId)
        );
        // Create: commenter must have read access to the parent submission (L-03)
        allow create: if isAuthenticated() && (
          isAdmin() ||
          get(/databases/$(database)/documents/snap_submissions/$(submissionId)).data.tenantId == request.auth.uid ||
          clientHasPluginAccess(get(/databases/$(database)/documents/snap_submissions/$(submissionId)).data.pluginId) ||
          hasTenantShareAccess(get(/databases/$(database)/documents/snap_submissions/$(submissionId)).data.pluginId)
        );
        allow update, delete: if isAuthenticated() && request.auth.uid == resource.data.authorUid;
      }

      match /history/{entryId} {
        allow read: if isAuthenticated() && (
          isAdmin() ||
          get(/databases/$(database)/documents/snap_submissions/$(submissionId)).data.tenantId == request.auth.uid ||
          clientHasPluginAccess(get(/databases/$(database)/documents/snap_submissions/$(submissionId)).data.pluginId) ||
          hasTenantShareAccess(get(/databases/$(database)/documents/snap_submissions/$(submissionId)).data.pluginId)
        );
        allow create: if isAuthenticated() && (
          isAdmin() ||
          get(/databases/$(database)/documents/snap_submissions/$(submissionId)).data.tenantId == request.auth.uid ||
          clientHasPluginAccess(get(/databases/$(database)/documents/snap_submissions/$(submissionId)).data.pluginId) ||
          hasTenantShareAccess(get(/databases/$(database)/documents/snap_submissions/$(submissionId)).data.pluginId)
        );
        allow update, delete: if false;
      }
    }

    // Client invitations
    match /tenant_shares/{shareId} {
      allow read: if isAuthenticated() && (
        resource.data.ownerTenantId == request.auth.uid ||
        resource.data.grantedTenantId == request.auth.uid ||
        isAdmin()
      );
      allow write: if isAdmin();
    }

    match /client_invitations/{inviteId} {
      // create: server-side only (Cloud Function). Direct client creates are denied (M-05).
      allow create: if isAdmin();
      allow read, update, delete: if isAdmin() || resource.data.tenantId == request.auth.uid;
    }

    // Admin API keys
    match /admin_api_keys/{apiKeyId} {
      allow read, write: if isAdmin();
    }

    // Snap counters — written exclusively by the submitSnap Cloud Function (pen test 7.2)
    match /snap_counters/{tenantId} {
      allow read, write: if false;
    }

    // HIPAA audit log — immutable read/view events for HIPAA snap access (G-02)
    match /audit_log/{logId} {
      // Only the authenticated viewer may create their own entry
      allow create: if isAuthenticated() && request.auth.uid == request.resource.data.viewedBy;
      // Tenant owner and admins may read entries for their tenant
      allow read: if isAuthenticated() && (
        isAdmin() ||
        request.auth.uid == resource.data.tenantId
      );
      // Immutable — no updates or deletes
      allow update, delete: if false;
    }
  }
}

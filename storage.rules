rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    function isAuthenticated() {
      return request.auth != null;
    }

    // Snap screenshots uploaded by the widget (uses idToken with custom claims)
    match /snap_screenshots/{tenantId}/{fileName} {
      allow create: if isAuthenticated() &&
        (request.auth.token.get('snap_tenantId', '') == tenantId ||
         request.auth.token.get('tenantId', '') == tenantId) &&
        request.resource.size < 20 * 1024 * 1024;
      allow read: if isAuthenticated();
      allow delete: if isAuthenticated() &&
        (request.auth.token.get('snap_tenantId', '') == tenantId ||
         request.auth.token.get('tenantId', '') == tenantId);
    }

    // Snap recordings uploaded by the widget
    match /snap_recordings/{tenantId}/{fileName} {
      allow create: if isAuthenticated() &&
        (request.auth.token.get('snap_tenantId', '') == tenantId ||
         request.auth.token.get('tenantId', '') == tenantId) &&
        request.resource.size < 100 * 1024 * 1024;
      allow read: if isAuthenticated();
      allow delete: if isAuthenticated() &&
        (request.auth.token.get('snap_tenantId', '') == tenantId ||
         request.auth.token.get('tenantId', '') == tenantId);
    }

    // Legacy path (keep for backwards compat)
    match /snaps/{pluginId}/{submissionId}/{fileName} {
      allow create: if isAuthenticated() &&
        request.resource.size < 20 * 1024 * 1024;
      allow read: if isAuthenticated();
      allow delete: if isAuthenticated();
    }

    // BAA documents and other tenant uploads
    match /tenants/{tenantId}/{fileName} {
      allow read, write: if isAuthenticated() && request.auth.uid == tenantId;
    }
  }
}

rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    function isAuthenticated() {
      return request.auth != null;
    }

    function isTenantOwner(tenantId) {
      return request.auth.uid == tenantId ||
        request.auth.token.get('tenantId', '') == tenantId ||
        request.auth.token.get('snap_tenantId', '') == tenantId;
    }

    // Snap screenshots uploaded by the widget (uses idToken with custom claims)
    match /snap_screenshots/{tenantId}/{fileName} {
      allow create: if isAuthenticated() &&
        isTenantOwner(tenantId) &&
        request.resource.size < 20 * 1024 * 1024;
      allow read: if isAuthenticated() && isTenantOwner(tenantId);
      allow delete: if isAuthenticated() && isTenantOwner(tenantId);
    }

    // HIPAA staging path — widget writes here; only admin SDK (Cloud Functions) can read/delete
    match /snap_screenshots_staging/{tenantId}/{fileName} {
      allow create: if isAuthenticated() &&
        isTenantOwner(tenantId) &&
        request.resource.size < 20 * 1024 * 1024;
      allow read: if false;
      allow delete: if false;
    }

    // Snap recordings uploaded by the widget
    match /snap_recordings/{tenantId}/{fileName} {
      allow create: if isAuthenticated() &&
        isTenantOwner(tenantId) &&
        request.resource.size < 100 * 1024 * 1024;
      allow read: if isAuthenticated() && isTenantOwner(tenantId);
      allow delete: if isAuthenticated() && isTenantOwner(tenantId);
    }

    // Legacy path — no longer in use; block all client access.
    // Screenshots now live under snap_screenshots/{tenantId}/.
    match /snaps/{pluginId}/{submissionId}/{fileName} {
      allow read, write: if false;
    }

    // Comment image attachments
    match /comment_images/{tenantId}/{snapId}/{fileName} {
      allow create: if isAuthenticated() &&
        isTenantOwner(tenantId) &&
        request.resource.size < 10 * 1024 * 1024 &&
        request.resource.contentType.matches('image/.*');
      allow read: if isAuthenticated() && isTenantOwner(tenantId);
      allow delete: if isAuthenticated() && isTenantOwner(tenantId);
    }

    // BAA documents and other tenant uploads
    match /tenants/{tenantId}/{fileName} {
      allow read, write: if isAuthenticated() && request.auth.uid == tenantId;
    }
  }
}
